# Build artifacts
build/
dist/
*.egg-info/
.eggs/

# Python
__pycache__/
*.pyc
*.pyo

# Virtualenvs
.venv/
venv/
env/

# Test / coverage / lint caches
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
